# Local Docker development template. Copied to `.env` by `pnpm setup` if missing.
# Production secrets live in `.env.production` (see `.env.production.example`).

DATABASE_URL=postgres://vaultchat:vaultchat@localhost:5432/vaultchat
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-to-a-long-random-string
GATEWAY_PUSH_SECRET=change-me-gateway-push-secret

API_BASE_URL=http://localhost:3000
WS_URL=ws://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

LOCAL_MEDIA_PATH=.data/media

STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:localhost:3478
TURN_SECRET=vaultchat-turn-dev-secret

# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_SECURE=true

SKIP_EMAIL_VERIFICATION=true
