# Database (Neon locally via Docker: postgres://vaultchat:vaultchat@localhost:5432/vaultchat)
DATABASE_URL=postgres://vaultchat:vaultchat@localhost:5432/vaultchat

# Redis (Upstash locally via Docker)
REDIS_URL=redis://localhost:6379

# Auth — metadata only, never message keys
JWT_SECRET=change-me-to-a-long-random-string

# App URLs
API_BASE_URL=http://localhost:3000
WS_URL=ws://localhost:3001

# Client-side (Next.js public env)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Media (Cloudflare R2 — production; omit for local file storage fallback)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=vaultchat-media
# LOCAL_MEDIA_PATH=.data/media

# WebRTC TURN (Phase 2 — coturn via pnpm infra:up)
# Use turn:localhost:3478 for same-machine browser tests.
# For mobile on LAN, use turn:<your-lan-ip>:3478
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=turn:localhost:3478
TURN_SECRET=vaultchat-turn-dev-secret

# Gateway → API push for incoming calls (optional)
GATEWAY_PUSH_SECRET=change-me-gateway-push-secret

# Email verification (optional — without SMTP, verification links are logged to the API console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=VaultChat <noreply@example.com>
# SMTP_SECURE=true
# Local dev convenience: auto-verify on register (do not use in production)
# SKIP_EMAIL_VERIFICATION=true
