{
  "identifier": "default",
  "description": "Default VaultChat desktop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "macos-permissions:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" },
        { "url": "https://chat.addjoybarreto.com" },
        { "url": "https://chat.addjoybarreto.com/*" },
        { "url": "https://*.vercel.app" },
        { "url": "https://*.vercel.app/*" },
        { "url": "https://vaultchat-gateway.fly.dev" },
        { "url": "https://vaultchat-gateway.fly.dev/*" }
      ]
    }
  ]
}
