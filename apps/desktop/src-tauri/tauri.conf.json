{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VaultChat",
  "version": "0.0.1",
  "identifier": "com.vaultchat.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:web",
    "beforeBuildCommand": "pnpm run build:web",
    "devUrl": "http://localhost:3002",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VaultChat",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "SocialNetworking",
    "shortDescription": "End-to-end encrypted chat",
    "longDescription": "VaultChat is a secure messaging app with Discord-style desktop UI. Messages are encrypted on your device before they leave.",
    "copyright": "Copyright © VaultChat",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "infoPlist": "./Info.plist",
      "entitlements": "./Entitlements.plist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": "((mailto:\\w+)|(tel:\\w+)|(https?://\\w+)|(x-apple\\.systempreferences:)).+"
    }
  }
}
